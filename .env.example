# ──────────────────────────────────────────────
# TeleTrader - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ──────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# Group/channel ID (negative number for groups, e.g. -1001234567890)
# Tip: Forward a message from the group to @userinfobot to get the ID
TELEGRAM_GROUP_ID=-1001234567890

# ── MetaTrader 5 ──────────────────────────────
MT5_LOGIN=123456
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Live

# ── Risk Management ───────────────────────────
DEFAULT_LOT_SIZE=0.01
MAX_LOT_SIZE=0.10
MAX_OPEN_TRADES=5
MAX_DAILY_LOSS_USD=100.0

# ── Symbol Whitelist (optional) ───────────────
# Leave empty to allow all symbols
# Comma-separated, no spaces: XAUUSD,EURUSD,GBPUSD
ALLOWED_SYMBOLS=
